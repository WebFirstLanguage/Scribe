// Scribe test suite.
//
// The engine is pulled in with `include from`, which exposes its actions to
// this file. Run from the repository root (so the fixture paths under build/
// resolve):
//
//     wfl --test tests/scribe.test.wfl
//
// or use the convenience script tests/run.sh.

include from "../src/scribe.wfl"

create map addr:
    "city" is "Paris"
end map
create map person:
    "name" is "Alice"
    "age" is 30
    "admin" is yes
    "addr" is addr
end map
store tag_list as ["wfl", "scribe", "twig"]
create map t_ctx:
    "user" is person
    "tags" is tag_list
    "title" is "Tom & Jerry <fun>"
    "num" is 7
    "blank" is ""
end map

describe "text and output":

    test "plain text passes through":
        store got as scribe_render of "hello world" and t_ctx
        expect got to equal "hello world"
    end test

    test "variable interpolation":
        store got as scribe_render of "Hi {{ user.name }}!" and t_ctx
        expect got to equal "Hi Alice!"
    end test

    test "nested path lookup":
        store got as scribe_render of "{{ user.addr.city }}" and t_ctx
        expect got to equal "Paris"
    end test

    test "list index in path":
        store got as scribe_render of "{{ tags.0 }}-{{ tags.2 }}" and t_ctx
        expect got to equal "wfl-twig"
    end test

    test "missing variable renders empty":
        store got as scribe_render of "start-{{ user.missing }}-end" and t_ctx
        expect got to equal "start--end"
    end test

    test "comments are stripped":
        store got as scribe_render of "a{# hidden #}b" and t_ctx
        expect got to equal "ab"
    end test

end describe

describe "auto-escaping and security":

    test "html is escaped by default":
        store got as scribe_render of "{{ title }}" and t_ctx
        expect got to equal "Tom &amp; Jerry &lt;fun&gt;"
    end test

    test "raw filter opts out of escaping":
        store got as scribe_render of "{{ title | raw }}" and t_ctx
        expect got to equal "Tom & Jerry <fun>"
    end test

    test "escape filter is explicit and not double-escaped":
        store got as scribe_render of "{{ title | escape }}" and t_ctx
        expect got to equal "Tom &amp; Jerry &lt;fun&gt;"
    end test

end describe

describe "conditionals":

    test "if true branch":
        store got as scribe_render of "{% if user.admin %}yes{% else %}no{% endif %}" and t_ctx
        expect got to equal "yes"
    end test

    test "if false branch":
        store got as scribe_render of "{% if num > 100 %}big{% else %}small{% endif %}" and t_ctx
        expect got to equal "small"
    end test

    test "elseif chain":
        store got as scribe_render of "{% if num > 100 %}a{% elseif num > 5 %}b{% else %}c{% endif %}" and t_ctx
        expect got to equal "b"
    end test

    test "comparison operators":
        store got as scribe_render of "{% if num == 7 %}eq{% endif %}{% if num >= 7 %}ge{% endif %}" and t_ctx
        expect got to equal "eqge"
    end test

    test "logical and / or / not":
        store got as scribe_render of "{% if user.admin and not (num > 100) %}ok{% endif %}" and t_ctx
        expect got to equal "ok"
    end test

end describe

describe "loops":

    test "for over a list":
        store got as scribe_render of "{% for t in tags %}{{ t }},{% endfor %}" and t_ctx
        expect got to equal "wfl,scribe,twig,"
    end test

    test "loop.index is 1-based":
        store got as scribe_render of "{% for t in tags %}{{ loop.index }}{% endfor %}" and t_ctx
        expect got to equal "123"
    end test

    test "loop.first and loop.last":
        store got as scribe_render of "{% for t in tags %}{% if loop.first %}<{% endif %}{{ t }}{% if loop.last %}>{% endif %}{% endfor %}" and t_ctx
        expect got to equal "<wflscribetwig>"
    end test

    test "for-else on empty collection":
        store got as scribe_render of "{% for x in missing %}X{% else %}none{% endfor %}" and t_ctx
        expect got to equal "none"
    end test

end describe

describe "set and expressions":

    test "set binds a variable":
        store got as scribe_render of "{% set g = 'Hi ' ~ user.name %}{{ g }}" and t_ctx
        expect got to equal "Hi Alice"
    end test

    test "arithmetic in output":
        store got as scribe_render of "{{ num * 3 + 1 }}" and t_ctx
        expect got to equal "22"
    end test

    test "string literal":
        store got as scribe_render of "{{ 'hello' }}" and t_ctx
        expect got to equal "hello"
    end test

end describe

describe "filters":

    test "upper and lower":
        store got as scribe_render of "{{ user.name | upper }}/{{ user.name | lower }}" and t_ctx
        expect got to equal "ALICE/alice"
    end test

    test "filter chain":
        store got as scribe_render of "{{ user.name | upper | lower }}" and t_ctx
        expect got to equal "alice"
    end test

    test "default on empty value":
        store got as scribe_render of "{{ blank | default('N/A') }}" and t_ctx
        expect got to equal "N/A"
    end test

    test "join a list":
        store got as scribe_render of "{{ tags | join(', ') }}" and t_ctx
        expect got to equal "wfl, scribe, twig"
    end test

    test "length of a list":
        store got as scribe_render of "{{ tags | length }}" and t_ctx
        expect got to equal "3"
    end test

    test "replace":
        store got as scribe_render of "{{ 'a-b-c' | replace('-', '+') }}" and t_ctx
        expect got to equal "a+b+c"
    end test

    test "first and last of a list":
        store got as scribe_render of "{{ tags | first }}/{{ tags | last }}" and t_ctx
        expect got to equal "wfl/twig"
    end test

    test "capitalize":
        store got as scribe_render of "{{ 'hello world' | capitalize }}" and t_ctx
        expect got to equal "Hello world"
    end test

end describe

describe "verbatim":

    test "verbatim emits its body literally":
        store got as scribe_render of "{% verbatim %}{{ user.name }} {% if x %}{% endif %}{% endverbatim %}" and t_ctx
        expect got to equal "{{ user.name }} {% if x %}{% endif %}"
    end test

end describe

describe "include and inheritance":

    test "include renders a partial with the current context":
        open file at "build/_scribe_partial.tmp" for writing as fh
        wait for write content "P:{{ user.name }}" into fh
        close file fh
        store got as scribe_render of "<{% include 'build/_scribe_partial.tmp' %}>" and t_ctx
        expect got to equal "<P:Alice>"
    end test

    test "extends overrides one block and keeps the default of another":
        open file at "build/_scribe_base.tmp" for writing as fb
        wait for write content "A{% block one %}D1{% endblock %}B{% block two %}D2{% endblock %}C" into fb
        close file fb
        store child as "{% extends 'build/_scribe_base.tmp' %}{% block two %}OVER{% endblock %}"
        store got as scribe_render of child and t_ctx
        expect got to equal "AD1BOVERC"
    end test

end describe

describe "multi-level inheritance":

    test "a base extends a grandparent across three levels":
        open file at "build/_sc_grand.tmp" for writing as fg
        wait for write content "<h>{% block head %}gh{% endblock %}</h><b>{% block body %}gb{% endblock %}</b>" into fg
        close file fg
        open file at "build/_sc_mid.tmp" for writing as fm
        wait for write content "{% extends 'build/_sc_grand.tmp' %}{% block body %}<m>{% block content %}mc{% endblock %}</m>{% endblock %}" into fm
        close file fm
        store child as "{% extends 'build/_sc_mid.tmp' %}{% block content %}CC{% endblock %}"
        store got as scribe_render of child and t_ctx
        expect got to equal "<h>gh</h><b><m>CC</m></b>"
    end test

    test "the most-derived override wins over an intermediate one":
        open file at "build/_sc_g2.tmp" for writing as fg2
        wait for write content "{% block t %}base{% endblock %}" into fg2
        close file fg2
        open file at "build/_sc_m2.tmp" for writing as fm2
        wait for write content "{% extends 'build/_sc_g2.tmp' %}{% block t %}mid{% endblock %}" into fm2
        close file fm2
        store child as "{% extends 'build/_sc_m2.tmp' %}{% block t %}leaf{% endblock %}"
        store got as scribe_render of child and t_ctx
        expect got to equal "leaf"
    end test

end describe

describe "macros":

    test "define and call a macro, calling before its definition":
        store t as "{{ hi('Sam') }}{% macro hi(n) %}Hi {{ n }}!{% endmacro %}"
        store got as scribe_render of t and t_ctx
        expect got to equal "Hi Sam!"
    end test

    test "macro output is trusted but its interpolations are escaped":
        store t as "{% macro tag(v) %}<i>{{ v }}</i>{% endmacro %}{{ tag('a & b') }}"
        store got as scribe_render of t and t_ctx
        expect got to equal "<i>a &amp; b</i>"
    end test

    test "a macro with a missing argument binds it to nothing":
        store t as "{% macro pair(a, b) %}{{ a }}-{{ b }}{% endmacro %}{{ pair('x') }}"
        store got as scribe_render of t and t_ctx
        expect got to equal "x-"
    end test

    test "import a macro namespace from a file":
        open file at "build/_sc_forms.tmp" for writing as ff
        wait for write content "{% macro field(n) %}<input name=\"{{ n }}\">{% endmacro %}" into ff
        close file ff
        store t as "{% import 'build/_sc_forms.tmp' as forms %}{{ forms.field('email') }}"
        store got as scribe_render of t and t_ctx
        expect got to equal "<input name=\"email\">"
    end test

    test "from import binds a macro by name":
        open file at "build/_sc_forms2.tmp" for writing as ff2
        wait for write content "{% macro field(n) %}[{{ n }}]{% endmacro %}" into ff2
        close file ff2
        store t as "{% from 'build/_sc_forms2.tmp' import field %}{{ field('x') }}"
        store got as scribe_render of t and t_ctx
        expect got to equal "[x]"
    end test

    test "an imported macro can call a sibling in its home file":
        open file at "build/_sc_lib.tmp" for writing as fl
        wait for write content "{% macro wrap(x) %}[{{ x }}]{% endmacro %}{% macro shout(x) %}{{ wrap(x) | upper }}{% endmacro %}" into fl
        close file fl
        store t as "{% from 'build/_sc_lib.tmp' import shout %}{{ shout('hi') }}"
        store got as scribe_render of t and t_ctx
        expect got to equal "[HI]"
    end test

end describe

describe "scoped includes":

    test "include with an explicit scoped context":
        open file at "build/_sc_badge.tmp" for writing as fbg
        wait for write content "<b class=\"{{ cls }}\">{{ label }}</b>" into fbg
        close file fbg
        store got as scribe_render of "{% include 'build/_sc_badge.tmp' with { cls: 'hot', label: 'NEW' } %}" and t_ctx
        expect got to equal "<b class=\"hot\">NEW</b>"
    end test

    test "include with only isolates the partial from the caller context":
        open file at "build/_sc_badge2.tmp" for writing as fbg2
        wait for write content "[{{ user.name }}|{{ label }}]" into fbg2
        close file fbg2
        store got as scribe_render of "{% include 'build/_sc_badge2.tmp' with { label: 'L' } only %}" and t_ctx
        expect got to equal "[|L]"
    end test

end describe

describe "new filters":

    test "truncate with the default suffix":
        store got as scribe_render of "{{ 'The quick brown fox' | truncate(9) }}" and t_ctx
        expect got to equal "The quick..."
    end test

    test "truncate with a custom suffix and short-string passthrough":
        store got as scribe_render of "{{ 'hi' | truncate(9, '') }}/{{ 'abcdefghij' | truncate(5, '!') }}" and t_ctx
        expect got to equal "hi/abcde!"
    end test

    test "striptags removes html markup":
        store got as scribe_render of "{{ '<b>bold</b> text' | striptags }}" and t_ctx
        expect got to equal "bold text"
    end test

    test "asset builds a root-relative path":
        store got as scribe_render of "{{ 'css/app.css' | asset }}" and t_ctx
        expect got to equal "/css/app.css"
    end test

    test "asset joins a base url without doubling the slash":
        store got as scribe_render of "{{ '/js/app.js' | asset('https://cdn.example.com/') }}" and t_ctx
        expect got to equal "https://cdn.example.com/js/app.js"
    end test

    test "url builds a root-relative route":
        store got as scribe_render of "{{ 'about' | url }}" and t_ctx
        expect got to equal "/about"
    end test

    test "date formats a date value with a strftime pattern":
        store d as parse_date of "2026-07-10" and "%Y-%m-%d"
        create map dctx:
            "d" is d
        end map
        store got as scribe_render of "{{ d | date('%d/%m/%Y') }}" and dctx
        expect got to equal "10/07/2026"
    end test

    test "markdown renders headings, emphasis, and paragraphs":
        store got as scribe_render of "{{ '# Hi\n\nA **bold** move.' | markdown }}" and t_ctx
        expect got to equal "<h1>Hi</h1><p>A <strong>bold</strong> move.</p>"
    end test

    test "markdown escapes raw html before formatting":
        store got as scribe_render of "{{ '<script>x</script>' | markdown }}" and t_ctx
        expect got to equal "<p>&lt;script&gt;x&lt;/script&gt;</p>"
    end test

end describe

describe "empty-collection rendering":

    test "an empty list renders as empty text, not [ ]":
        store empty_list as []
        create map ectx:
            "items" is empty_list
        end map
        store got as scribe_render of "before-{{ items }}-after" and ectx
        expect got to equal "before--after"
    end test

end describe
